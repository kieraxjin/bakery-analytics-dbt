-- THREE: INGREDIENTS NEEDED BASED ON BATCH SIZE
with ingredient_list as (select trial_id 
,string_agg(upper(substring(ingredient_name, 1,1)) || lower(substring(ingredient_name, 2, len(ingredient_name)- 1 )) || ' ' || amount_half_batch || ' ' || unit ,E'\n' )  as half_batch
,string_agg(upper(substring(ingredient_name, 1,1)) || lower(substring(ingredient_name, 2, len(ingredient_name)- 1 )) || ' ' || ingredient_amount || ' ' || unit ,E'\n' )  as full_batch
,string_agg(upper(substring(ingredient_name, 1,1)) || lower(substring(ingredient_name, 2, len(ingredient_name)- 1 )) || ' ' || amount_double_batch || ' ' || unit ,E'\n' )  as double_batch

from stg_ingredients
group by trial_id )


select s.recipe_id 
,s.recipe_name
,r.trial_id
,r.trial_date
,i.half_batch
,i.full_batch
,i.double_batch

from ingredient_list i
join stg_recipe_trials r on i.trial_id = r.trial_id
join stg_recipes s on r.recipe_id = s.recipe_id;







